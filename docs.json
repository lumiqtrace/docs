{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "LumiqTrace",
  "colors": {
    "primary": "#00d4ff",
    "light": "#33ddff",
    "dark": "#00b8e0"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Inter",
    "heading": {
      "family": "Inter",
      "weight": 700
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "one-dark-pro"
      }
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Changelog",
        "href": "/reference/changelog"
      },
      {
        "label": "Status",
        "href": "https://status.lumiqtrace.com"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/lumiqtrace"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "API Reference",
          "icon": "square-terminal",
          "href": "/api-reference/authentication"
        },
        {
          "anchor": "Changelog",
          "icon": "clock",
          "href": "/reference/changelog"
        },
        {
          "anchor": "Status",
          "icon": "circle-check",
          "href": "https://status.lumiqtrace.com"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "concepts",
              "troubleshooting"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/environments",
              "guides/serverless",
              "guides/production-checklist",
              "guides/webhooks"
            ]
          },
          {
            "group": "SDK — TypeScript",
            "pages": [
              "sdk/typescript",
              "sdk/agent-tracing",
              "sdk/manual-spans",
              "sdk/guardrails",
              "sdk/prompt-management",
              "sdk/pii-redaction",
              "sdk/config-propagation"
            ]
          },
          {
            "group": "SDK — Python",
            "pages": [
              "sdk/python",
              "sdk/fastapi-middleware",
              "sdk/flask-middleware"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "sdk/langchain",
              "sdk/google-adk",
              "sdk/integrations"
            ]
          },
          {
            "group": "Dashboard",
            "pages": [
              "dashboard/overview",
              "dashboard/traces",
              "dashboard/costs",
              "dashboard/performance",
              "dashboard/alerts",
              "dashboard/evaluations",
              "dashboard/guardrails",
              "dashboard/prompts",
              "dashboard/simulations",
              "dashboard/incidents",
              "dashboard/sessions",
              "dashboard/lumiqpilot",
              "dashboard/ai-features"
            ]
          },
          {
            "group": "Account & Billing",
            "pages": [
              "account/organizations",
              "account/api-keys",
              "account/billing"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/self-hosting",
              "platform/environment-variables",
              "platform/security"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/span-kinds",
              "reference/models",
              "reference/changelog"
            ]
          }
        ]
      }
    ]
  }
}
