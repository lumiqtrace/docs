{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "LumiqTrace",
  "colors": {
    "primary": "#00d4ff",
    "light": "#33ddff",
    "dark": "#00b8e0"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "family": "Manrope",
    "heading": {
      "family": "Sora",
      "weight": 700
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "one-dark-pro"
      }
    }
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "seo": {
    "indexing": "all"
  },
  "metadata": {
    "og:site_name": "LumiqTrace Docs",
    "og:image": "https://docs.lumiqtrace.com/images/og.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Changelog",
        "href": "/reference/changelog"
      },
      {
        "label": "Status",
        "href": "https://status.lumiqtrace.com"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/lumiqtrace"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "API Reference",
          "icon": "square-terminal",
          "href": "/api-reference/authentication"
        },
        {
          "anchor": "Changelog",
          "icon": "clock",
          "href": "/reference/changelog"
        },
        {
          "anchor": "Status",
          "icon": "circle-check",
          "href": "https://status.lumiqtrace.com"
        }
      ]
    },
    "tabs": [
      {
        "tab": "SDK & Integrations",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "concepts",
              "troubleshooting"
            ]
          },
          {
            "group": "TypeScript SDK",
            "pages": [
              "sdk/typescript",
              "sdk/agent-tracing",
              "sdk/manual-spans",
              "sdk/guardrails",
              "sdk/prompt-management",
              "sdk/pii-redaction",
              "sdk/config-propagation"
            ]
          },
          {
            "group": "Python SDK",
            "pages": [
              "sdk/python",
              "sdk/fastapi-middleware",
              "sdk/flask-middleware"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "sdk/integrations/openai",
              "sdk/integrations/anthropic",
              "sdk/integrations/google-genai",
              "sdk/integrations/bedrock",
              "sdk/integrations/openrouter",
              "sdk/integrations/mistral",
              "sdk/integrations/groq",
              "sdk/integrations/litellm",
              "sdk/integrations/langchain",
              "sdk/integrations/google-adk"
            ]
          },
          {
            "group": "MCP Server",
            "pages": [
              "guides/lumiqtrace-mcp"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/environments",
              "guides/serverless",
              "guides/production-checklist",
              "guides/webhooks",
              "guides/testing-and-mocking"
            ]
          }
        ]
      },
      {
        "tab": "Dashboard",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "dashboard/overview"
            ]
          },
          {
            "group": "Traces & Sessions",
            "pages": [
              "dashboard/traces",
              "dashboard/sessions"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "dashboard/agent-registry",
              "dashboard/agents"
            ]
          },
          {
            "group": "Costs",
            "pages": [
              "dashboard/costs"
            ]
          },
          {
            "group": "Quality",
            "pages": [
              "dashboard/evaluations",
              "dashboard/guardrails",
              "dashboard/simulations",
              "dashboard/datasets"
            ]
          },
          {
            "group": "Reliability",
            "pages": [
              "dashboard/alerts",
              "dashboard/incidents",
              "dashboard/errors"
            ]
          },
          {
            "group": "AI Features",
            "pages": [
              "dashboard/lumiqpilot",
              "dashboard/ai-features"
            ]
          },
          {
            "group": "Prompts & Tools",
            "pages": [
              "dashboard/prompts",
              "dashboard/tools"
            ]
          },
          {
            "group": "Performance",
            "pages": [
              "dashboard/performance"
            ]
          }
        ]
      },
      {
        "tab": "Platform",
        "groups": [
          {
            "group": "Deployment",
            "pages": [
              "platform/self-hosting",
              "platform/environment-variables"
            ]
          },
          {
            "group": "Security & Compliance",
            "pages": [
              "platform/security",
              "platform/audit"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "account/organizations",
              "account/api-keys",
              "account/billing"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Reference",
            "pages": [
              "api-reference/authentication",
              "api-reference/ingest",
              "api-reference/otel",
              "api-reference/events",
              "api-reference/traces",
              "api-reference/metrics",
              "api-reference/errors"
            ]
          }
        ]
      }
    ],
    "redirects": [
      { "source": "/sdk/langchain", "destination": "/sdk/integrations/langchain" },
      { "source": "/sdk/google-adk", "destination": "/sdk/integrations/google-adk" },
      { "source": "/sdk/integrations", "destination": "/sdk/integrations/openai" }
    ]
  }
}
