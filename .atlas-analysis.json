  "keyFeatures": [
    "Automatic LLM call tracing with zero-config wrappers for OpenAI, Anthropic, and Google Gemini",
    "Real-time cost tracking and token usage analytics per model, project, and user",
    "Multi-agent tracing with hierarchical span visualization and FlameGraph",
    "AI-powered cost optimizer with actionable recommendations (Claude Sonnet)",
    "Anomaly detection with automatic explanations (Gemini Flash)",
    "Natural language query over trace data",
    "Root cause analysis for failed traces using Claude Extended Thinking",
    "Prompt management with versioning, labels, and runtime fetching",
    "Guardrails for pre/post LLM content checking",
    "LangChain and Google ADK native integrations",
    "Multi-tenant organization management with RBAC",
    "Configurable alerts with email and webhook notifications",
    "OpenTelemetry-compatible tracing export"
  ],
  "publicApiSurface": [
    "init(opts) / initLumiqtrace(opts)",
    "wrapOpenAI(client)",
    "wrapAnthropic(client)",
    "wrapGoogle(client)",
    "wrapOpenRouter(client)",
    "startSpan(opts)",
    "withAgent(opts, fn)",
    "withLumiqtraceContext(opts, fn)",
    "LumiqtraceCallbackHandler (LangChain)",
    "wrapADKAgent / wrapADKRunner / instrumentADK (Google ADK)",
    "PromptClient.get(name, opts)",
    "PromptClient.create(params)",
    "PromptClient.compile(prompt, variables)",
    "GuardrailBlockedError",
    "initOTel(config)",
    "lumiqtrace.init() / patch_openai() [Python]",
    "@trace decorator [Python]",
    "with_agent context manager [Python]",
    "POST /v1/ingest",
    "GET /v1/projects/:id/overview",
    "GET /v1/events",
    "GET /v1/traces/:traceId",
    "GET /v1/costs",
    "GET /v1/performance",
    "GET /v1/errors",
    "GET /v1/ai/cost-optimizer",
    "POST /v1/ai/nl-query",
    "POST /v1/ai/root-cause/:traceId",
    "GET /v1/prompts/:name",
    "POST /v1/prompts"
  ]
